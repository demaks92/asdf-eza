#!/usr/bin/env bash

set -euo pipefail

# shellcheck source=../lib/utils.bash
. "$(dirname "$0")/../lib/utils.bash"

git ls-remote --tags --refs "$GH_REPO" |
  grep -o 'refs/tags/.*' |
  cut -d/ -f3- |
  sed 's/^v//' |
  grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' |
  sed 'h; s/[+-]/./g; s/.p\([[:digit:]]\)/.z\1/; s/$/.z/; G; s/\n/ /' |
  LC_ALL=C sort -t. -k 1,1n -k 2,2n -k 3,3n -k 4,4n -k 5,5n |
  awk '{print $2}' |
  xargs -r printf '%s '
